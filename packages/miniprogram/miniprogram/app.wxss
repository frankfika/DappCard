/**
 * 全局样式 - DappCard Light Mode
 * Design System: 明亮、极简、高级感、年轻活力
 */

/* ==================== 基础设置 ==================== */
view, scroll-view, text, image, button, input, textarea, navigator {
  box-sizing: border-box;
}

page {
  /* 背景 */
  --color-bg: #fafafa;
  --color-bg-elevated: #ffffff;
  --color-bg-card: #ffffff;
  --color-surface: #f5f5f5;
  --color-border: #f0f0f0;
  --color-border-light: #f5f5f5;

  /* 文本 */
  --color-text: #111111;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;

  /* 主色 */
  --color-primary: #111111;
  --color-primary-dark: #000000;
  --color-primary-light: #e5e5e5;
  --color-primary-soft: #f5f5f5;

  /* 强调色 - 年轻活力蓝 */
  --color-accent: #2563eb;
  --color-accent-dark: #1d4ed8;
  --color-accent-soft: rgba(37, 99, 235, 0.08);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 100rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 阴影 - 极柔和的灰色 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --shadow-glow: 0 4rpx 20rpx rgba(37, 99, 235, 0.12);

  background: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ==================== 安全区域 ==================== */
.safe-bottom {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ==================== 文字系统 ==================== */
.text-display {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
  line-height: 1.2;
}

.text-title {
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.text-headline {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.text-body {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.6;
}

.text-caption {
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.text-label {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: var(--color-text-tertiary);
}

/* 文字颜色 */
.text-primary { color: var(--color-text); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }

/* ==================== 卡片系统 ==================== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.card-elevated {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border);
}

.card-accent {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.04) 0%, rgba(37, 99, 235, 0.01) 100%);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-glow);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
}

/* ==================== 按钮系统 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  border-radius: var(--radius-full);
  transition: all 0.2s ease;
}

.btn-primary {
  height: 100rpx;
  padding: 0 48rpx;
  background: #111;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.85;
}

.btn-secondary {
  height: 88rpx;
  padding: 0 40rpx;
  background: #fff;
  color: #111;
  font-size: 28rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: var(--radius-full);
}

.btn-secondary:active {
  background: #f5f5f5;
}

/* ==================== 标签系统 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--color-text-secondary);
  border: 1rpx solid #f0f0f0;
}

.tag-active {
  background: #111;
  color: #fff;
  border-color: #111;
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes glow {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ==================== 工具类 ==================== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-1 { flex: 1; }

.w-full { width: 100%; }
.h-full { height: 100%; }

.rounded-full { border-radius: 50%; }

/* ==================== TabBar 占位 ==================== */
.tabbar-placeholder {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ==================== 隐私协议弹窗 ==================== */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-dialog {
  width: 580rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid #f0f0f0;
}

.privacy-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  text-align: center;
  margin-bottom: 24rpx;
}

.privacy-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: center;
  margin-bottom: 40rpx;
}

.privacy-link {
  color: #2563eb;
  font-weight: 500;
}

.privacy-buttons {
  display: flex;
  gap: 24rpx;
}

.privacy-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn.reject {
  background: #f5f5f5;
  color: #666;
}

.privacy-btn.agree {
  background: #111;
  color: #fff;
}
