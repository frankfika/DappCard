/**
 * 全局样式 - 温馨浪漫风格
 * Design System: 温暖、柔和、浪漫、有爱
 */

/* ==================== 基础设置 ==================== */
page {
  /* 背景 - 柔和奶油粉 */
  --color-bg: #fef7f4;
  --color-bg-elevated: #ffffff;
  --color-bg-card: #ffffff;
  --color-surface: #fff5f3;
  --color-border: #fce4df;
  --color-border-light: #fff0ed;

  /* 文本 - 温暖棕色调 */
  --color-text: #4a3f3a;
  --color-text-secondary: #8b7e78;
  --color-text-tertiary: #b5a9a3;

  /* 主色 - 甜蜜珊瑚粉 */
  --color-primary: #ff8a80;
  --color-primary-dark: #e57373;
  --color-primary-light: #ffcdd2;
  --color-primary-soft: #fff0ee;

  /* 强调色 - 浪漫玫瑰 */
  --color-accent: #f48fb1;
  --color-accent-dark: #ec407a;
  --color-accent-soft: #fce4ec;

  /* 辅助色 */
  --color-love: #ff6b6b;
  --color-heart: #ff8a9b;
  --color-warm: #ffab91;
  --color-soft: #f8bbd9;

  /* 圆角 - 更圆润 */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-full: 100rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 阴影 - 柔和粉调 */
  --shadow-sm: 0 2rpx 8rpx rgba(255, 138, 128, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(255, 138, 128, 0.12);
  --shadow-lg: 0 8rpx 32rpx rgba(255, 138, 128, 0.16);
  --shadow-glow: 0 4rpx 20rpx rgba(255, 138, 128, 0.25);

  background: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ==================== 安全区域 ==================== */
.safe-bottom {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ==================== 文字系统 ==================== */
.text-display {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
  line-height: 1.2;
}

.text-title {
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.text-headline {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.text-body {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.6;
}

.text-caption {
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.text-label {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  color: var(--color-text-tertiary);
}

/* 文字颜色 */
.text-primary { color: var(--color-text); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-love { color: var(--color-love); }

/* ==================== 卡片系统 ==================== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.card-elevated {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

.card-love {
  background: linear-gradient(135deg, #fff5f5 0%, #fff0f3 100%);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-glow);
  border: 1rpx solid var(--color-primary-light);
}

/* ==================== 按钮系统 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  border-radius: var(--radius-full);
  transition: all 0.2s ease;
}

.btn-primary {
  height: 100rpx;
  padding: 0 48rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: var(--shadow-glow);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.btn-secondary {
  height: 88rpx;
  padding: 0 40rpx;
  background: var(--color-bg-card);
  color: var(--color-text);
  font-size: 28rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-full);
}

.btn-secondary:active {
  background: var(--color-surface);
}

.btn-love {
  height: 96rpx;
  padding: 0 48rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #ff80ab 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 128, 0.4);
}

/* ==================== 标签系统 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: var(--color-surface);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.tag-love {
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes glow {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ==================== 工具类 ==================== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-1 { flex: 1; }

.w-full { width: 100%; }
.h-full { height: 100%; }

.rounded-full { border-radius: 50%; }

/* ==================== TabBar 占位 ==================== */
.tabbar-placeholder {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ==================== 隐私协议弹窗 ==================== */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-dialog {
  width: 580rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.privacy-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #4a3f3a;
  text-align: center;
  margin-bottom: 24rpx;
}

.privacy-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  text-align: center;
  margin-bottom: 40rpx;
}

.privacy-link {
  color: #ff8a80;
  font-weight: 500;
}

.privacy-buttons {
  display: flex;
  gap: 24rpx;
}

.privacy-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn.reject {
  background: #f5f5f5;
  color: #999999;
}

.privacy-btn.agree {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
}
