.page {
  min-height: 100vh;
  background: #fafafa;
  color: #111;
  display: flex;
  flex-direction: column;
}
.game-header {
  padding: 40rpx 48rpx 24rpx;
  text-align: center;
}
.game-title {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  color: #111;
}
.game-subtitle {
  font-size: 26rpx;
  color: #888;
}
.game-body {
  flex: 1;
  padding: 0 48rpx 48rpx;
}
.card-display {
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 28rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  margin-bottom: 40rpx;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.card-question {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 24rpx;
  color: #111;
}
.card-source {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
}
.card-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}
.card-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  color: #666;
}
.card-placeholder {
  background: #fff;
  border: 2rpx dashed #e5e5e5;
  border-radius: 28rpx;
  padding: 80rpx 48rpx;
  text-align: center;
  margin-bottom: 40rpx;
}
.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.placeholder-text {
  font-size: 28rpx;
  color: #888;
}
.game-stats {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  margin-bottom: 40rpx;
}
.stat-item {
  text-align: center;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 4rpx;
  color: #111;
}
.stat-label {
  font-size: 22rpx;
  color: #888;
}
.game-actions {
  margin-bottom: 40rpx;
}
.draw-btn {
  background: #111;
  color: #fff;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 100rpx;
  line-height: 100rpx;
  border: none;
}
.draw-btn::after { border: none; }
.secondary-actions {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}
.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid #f0f0f0;
}
.action-fav {
  background: rgba(255,100,100,0.06);
  border-color: rgba(255,100,100,0.15);
}
.action-btn-icon {
  font-size: 32rpx;
}
.action-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}
.filter-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  font-weight: 600;
  color: #888;
}
.toggle-icon {
  font-size: 24rpx;
}
.filters-panel {
  padding-bottom: 24rpx;
}
.filter-section {
  margin-bottom: 24rpx;
}
.filter-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}
.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  border: 1rpx solid #eee;
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}
.filter-chip-active {
  background: #111;
  color: #fff;
}
.history-list {
  padding-bottom: 24rpx;
}
.history-item {
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}
.history-question {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #111;
}
.history-source {
  font-size: 22rpx;
  color: #888;
}
.reset-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #ff6464;
  font-weight: 600;
}
