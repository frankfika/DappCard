/* Complete rewrite for Premium Modern UI */
.page {
  height: 100vh;
  background: #f4f5f7;
  color: #111;
  display: flex;
  flex-direction: column;
}
.tag-bar { padding: 24rpx 32rpx; border-bottom: none; background: transparent; }
.tag-scroll { white-space: nowrap; width: 100%; }
.tag-list { display: flex; gap: 20rpx; }
.filter-tag { padding: 16rpx 36rpx; border-radius: 100rpx; background: #fff; font-size: 28rpx; font-weight: 800; color: #666; flex-shrink: 0; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); }
.filter-tag-active { background: #111; color: #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15); }

.feed-scroll { flex: 1; padding: 0 32rpx; min-height: 0; width: 100%; }
.thread-list { display: flex; flex-direction: column; gap: 32rpx; }
.thread-card { background: #fff; border: none; border-radius: 48rpx; padding: 40rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04); }

.thread-header { margin-bottom: 24rpx; }
.author-info { display: flex; align-items: center; gap: 24rpx; }
.author-avatar { width: 96rpx; height: 96rpx; border-radius: 32rpx; background: #f5f5f5; }
.author-avatar-placeholder { background: #e0e0e0; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 40rpx; font-weight: bold; }
.author-meta { flex: 1; }
.author-name { font-size: 34rpx; font-weight: 900; color: #111; }
.author-handle { font-size: 26rpx; color: #888; margin-top: 4rpx; font-weight: 600; }

.thread-content { font-size: 32rpx; line-height: 1.6; margin-bottom: 24rpx; color: #222; font-weight: 500; }

.thread-images { display: grid; gap: 16rpx; margin-bottom: 24rpx; border-radius: 32rpx; overflow: hidden; }
.images-1 { grid-template-columns: 1fr; }
.images-1 .thread-img { height: 300rpx; aspect-ratio: 16/9; }
.images-2 { grid-template-columns: 1fr 1fr; }
.images-3 { grid-template-columns: 1fr 1fr 1fr; }
.thread-img { width: 100%; height: 300rpx; aspect-ratio: 1; background: #f5f5f5; }

.thread-tags { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx; }
.thread-tag { font-size: 26rpx; font-weight: 800; color: #666; background: #f4f5f7; padding: 10rpx 24rpx; border-radius: 16rpx; }

.thread-actions { display: flex; gap: 48rpx; border-top: 2rpx solid #f4f5f7; padding-top: 32rpx; }
.action-btn { display: flex; align-items: center; gap: 12rpx; color: #888; transition: all 0.2s; }
.action-active { color: #111; }
.action-icon { font-size: 36rpx; }
.action-text { font-size: 28rpx; font-weight: 700; }

.bottom-space { height: 240rpx; }

.fab { position: fixed; right: 40rpx; bottom: calc(180rpx + env(safe-area-inset-bottom)); width: 128rpx; height: 128rpx; border-radius: 64rpx; background: #111; color: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.25); z-index: 10; transition: transform 0.2s; }
.fab:active { transform: scale(0.9); }
.fab-icon { font-size: 64rpx; font-weight: 300; line-height: 1; margin-bottom: 8rpx; }
.hidden { display: none; }