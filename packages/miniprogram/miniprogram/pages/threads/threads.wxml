<view class="page">
  <!-- Header Tags -->
  <view class="tag-bar">
    <scroll-view scroll-x class="tag-scroll" show-scrollbar="{{false}}">
      <view class="tag-list">
        <view wx:for="{{tags}}" wx:key="*this" class="filter-tag {{activeTag === item ? 'filter-tag-active' : ''}}" bindtap="selectTag" data-tag="{{item}}">{{item}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- Threads Feed -->
  <scroll-view scroll-y class="feed-scroll">
    <view class="thread-list">
      <view wx:for="{{threads}}" wx:key="id" wx:for-item="thread" class="thread-card {{activeTag === 'All' || thread.tags.includes(activeTag) ? '' : 'hidden'}}">
        <!-- Author -->
        <view class="thread-header">
          <view class="author-info">
            <image wx:if="{{thread.author.avatar}}" class="author-avatar" src="{{thread.author.avatar}}" mode="aspectFill" />
            <view wx:else class="author-avatar author-avatar-placeholder">{{thread.author.name ? thread.author.name[0] : '?'}}</view>
            <view class="author-meta">
              <view class="author-name">{{thread.author.name}}</view>
              <view class="author-handle">{{thread.author.handle}} · {{thread.timestamp}}</view>
            </view>
          </view>
        </view>

        <!-- Content -->
        <view class="thread-content">{{thread.content}}</view>

        <!-- Images -->
        <view wx:if="{{thread.images && thread.images.length > 0}}" class="thread-images {{thread.images.length === 1 ? 'images-1' : thread.images.length === 2 ? 'images-2' : 'images-3'}}">
          <image wx:for="{{thread.images}}" wx:for-item="img" wx:key="*this" class="thread-img" src="{{img}}" mode="aspectFill" bindtap="previewImage" data-url="{{img}}" data-urls="{{thread.images}}" />
        </view>

        <!-- Tags -->
        <view class="thread-tags">
          <view wx:for="{{thread.tags}}" wx:for-item="tag" wx:key="*this" class="thread-tag">#{{tag}}</view>
        </view>

        <!-- Actions -->
        <view class="thread-actions">
          <view class="action-btn {{thread.isLiked ? 'action-active' : ''}}" bindtap="handleLike" data-id="{{thread.id}}">
            <text class="action-icon">{{thread.isLiked ? '👍' : '👆'}}</text>
            <text class="action-text">{{thread.likes > 0 ? thread.likes : 'Like'}}</text>
          </view>
          <view class="action-btn">
            <text class="action-icon">↗️</text>
            <text class="action-text">Share</text>
          </view>
        </view>
      </view>
    </view>
    <view class="bottom-space" />
  </scroll-view>

  <!-- FAB -->
  <view class="fab" bindtap="openPublish">
    <text class="fab-icon">+</text>
  </view>
</view>
