/* pages/my-activities/my-activities.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
}

/* Tabs */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  position: relative;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active .tab-text {
  color: #ff8a80;
  font-weight: 700;
  font-size: 32rpx;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  border-radius: 3rpx;
}

/* Tab Content */
.tab-content {
  padding: 20rpx 30rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* Loading State */
.loading-wrapper {
  padding: 80rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
