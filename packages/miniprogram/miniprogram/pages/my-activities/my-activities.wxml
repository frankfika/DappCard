<!--pages/my-activities/my-activities.wxml-->
<view class="container">
  <!-- Tabs -->
  <view class="tabs">
    <view
      class="tab-item {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="onTabChange"
    >
      <text class="tab-text">{{item}}</text>
      <view class="tab-indicator" wx:if="{{currentTab === index}}"></view>
    </view>
  </view>

  <!-- Tab Content -->
  <view class="tab-content">
    <!-- Created Activities -->
    <view class="activity-list" wx:if="{{currentTab === 0}}">
      <block wx:for="{{createdActivities}}" wx:key="_id">
        <activity-card
          activity="{{item}}"
          data-id="{{item._id}}"
          bindtap="onActivityTap"
        />
      </block>

      <view class="empty-state" wx:if="{{!loading && createdActivities.length === 0}}">
        <image class="empty-icon" src="/images/empty-created.png" mode="aspectFit"></image>
        <text class="empty-text">还没有创建过活动</text>
        <text class="empty-hint">去发起一个邀约吧～</text>
      </view>
    </view>

    <!-- Joined Activities -->
    <view class="activity-list" wx:if="{{currentTab === 1}}">
      <block wx:for="{{joinedActivities}}" wx:key="_id">
        <activity-card
          activity="{{item}}"
          data-id="{{item._id}}"
          bindtap="onActivityTap"
        />
      </block>

      <view class="empty-state" wx:if="{{!loading && joinedActivities.length === 0}}">
        <image class="empty-icon" src="/images/empty-joined.png" mode="aspectFit"></image>
        <text class="empty-text">还没有参加过活动</text>
        <text class="empty-hint">去发现页看看吧～</text>
      </view>
    </view>

    <!-- Applied Activities -->
    <view class="activity-list" wx:if="{{currentTab === 2}}">
      <block wx:for="{{appliedActivities}}" wx:key="_id">
        <activity-card
          activity="{{item}}"
          data-id="{{item._id}}"
          bindtap="onActivityTap"
        />
      </block>

      <view class="empty-state" wx:if="{{!loading && appliedActivities.length === 0}}">
        <image class="empty-icon" src="/images/empty-applied.png" mode="aspectFit"></image>
        <text class="empty-text">还没有申请过活动</text>
        <text class="empty-hint">快去申请感兴趣的活动吧～</text>
      </view>
    </view>
  </view>

  <!-- Loading State -->
  <view wx:if="{{loading}}" class="loading-wrapper">
    <text class="loading-text">加载中...</text>
  </view>
</view>
