<!--miniprogram/pages/profile-edit/profile-edit.wxml-->
<view class="container">
  <view class="form-section">
    <!-- Avatar -->
    <view class="form-item">
      <view class="form-label">头像</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="avatar-tip">点击更换</view>
      </button>
    </view>

    <!-- Nickname -->
    <view class="form-item">
      <view class="form-label">昵称</view>
      <input
        class="form-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <!-- Bio -->
    <view class="form-item">
      <view class="form-label">个性签名</view>
      <textarea
        class="form-textarea"
        placeholder="介绍一下自己吧~"
        value="{{bio}}"
        bindinput="onBioInput"
        maxlength="100"
        show-confirm-bar="{{false}}"
      ></textarea>
    </view>

    <!-- Gender -->
    <view class="form-item">
      <view class="form-label">性别</view>
      <picker
        mode="selector"
        range="{{genderOptions}}"
        range-key="label"
        bindchange="onGenderChange"
      >
        <view class="form-picker">
          <text wx:if="{{gender}}">
            {{genderLabel}}
          </text>
          <text wx:else class="placeholder">请选择性别</text>
        </view>
      </picker>
    </view>

    <!-- Birthday -->
    <view class="form-item">
      <view class="form-label">生日</view>
      <picker
        mode="date"
        value="{{birthday}}"
        start="1950-01-01"
        end="{{today}}"
        bindchange="onBirthdayChange"
      >
        <view class="form-picker">
          <text wx:if="{{birthday}}">{{birthday}}</text>
          <text wx:else class="placeholder">请选择生日</text>
        </view>
      </picker>
    </view>

    <!-- Region -->
    <view class="form-item">
      <view class="form-label">所在地</view>
      <picker
        mode="region"
        bindchange="onRegionChange"
        value="{{[province, city]}}"
      >
        <view class="form-picker">
          <text wx:if="{{city}}">{{province}} {{city}}</text>
          <text wx:else class="placeholder">请选择城市</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- Interests -->
  <view class="section">
    <view class="section-title">兴趣爱好</view>
    <view class="tag-grid">
      <view
        class="tag-item {{interests.includes(item) ? 'active' : ''}}"
        wx:for="{{allInterests}}"
        wx:key="index"
        data-interest="{{item}}"
        bindtap="toggleInterest"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- Companion Types -->
  <view class="section">
    <view class="section-title">寻找搭子类型</view>
    <view class="tag-grid">
      <view
        class="tag-item {{companionTypes.includes(item) ? 'active' : ''}}"
        wx:for="{{allCompanionTypes}}"
        wx:key="index"
        data-type="{{item}}"
        bindtap="toggleCompanionType"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- Save Button -->
  <view class="save-btn" bindtap="handleSave">
    <text>保存</text>
  </view>
</view>
