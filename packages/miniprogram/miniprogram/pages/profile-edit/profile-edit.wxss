/* miniprogram/pages/profile-edit/profile-edit.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding: 30rpx;
  padding-bottom: 150rpx;
}

/* Form Section */
.form-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #4a3f3a;
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* Avatar */
.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 2rpx solid #eeeeee;
}

.avatar-tip {
  font-size: 24rpx;
  color: #ff8a80;
  margin-top: 16rpx;
}

/* Input */
.form-input {
  width: 100%;
  font-size: 30rpx;
  color: #4a3f3a;
  padding: 20rpx 0;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  font-size: 30rpx;
  color: #4a3f3a;
  padding: 20rpx 0;
}

/* Picker */
.form-picker {
  font-size: 30rpx;
  color: #4a3f3a;
  padding: 20rpx 0;
}

.placeholder {
  color: #cccccc;
}

/* Section */
.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  color: #4a3f3a;
  font-weight: 600;
  margin-bottom: 30rpx;
}

/* Tag Grid */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-item {
  background: #fef7f4;
  color: #4a3f3a;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.tag-item.active {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  border-color: #ff8a80;
}

/* Save Button */
.save-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx 0;
  box-shadow: 0 -4rpx 20rpx rgba(255, 138, 128, 0.2);
}
