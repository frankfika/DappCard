/* pages/user-profile/user-profile.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding-bottom: 40rpx;
}

/* User Header */
.user-header {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  padding: 60rpx 30rpx 80rpx;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.user-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

/* Stats Section */
.stats-section {
  display: flex;
  background-color: #fff;
  margin: -40rpx 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 128, 0.15);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  color: #ff8a80;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

/* Section */
.section {
  background-color: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 20rpx;
}

/* Interests */
.interest-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.interest-tag {
  padding: 12rpx 24rpx;
  background-color: #ffe8e5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #ff8a80;
}

/* Activity List */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Reviews */
.review-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.review-item {
  padding: 24rpx;
  background-color: #fef7f4;
  border-radius: 12rpx;
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reviewer-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  margin-right: 16rpx;
}

.reviewer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.reviewer-name {
  font-size: 26rpx;
  color: #4a3f3a;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.review-time {
  font-size: 22rpx;
  color: #999;
}

.rating-stars {
  margin-left: auto;
}

.stars {
  font-size: 24rpx;
  color: #ffb300;
}

.review-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.empty-reviews {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Action Buttons */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #fff;
}

.action-btn.secondary {
  background-color: #f5f5f5;
  color: #666;
}

.action-btn.danger {
  background-color: #fff;
  color: #ff4444;
  border: 2rpx solid #ff4444;
}

.action-btn.blocked {
  background-color: #e0e0e0;
  color: #999;
}

/* Loading State */
.loading-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fef7f4;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
