<!--pages/create-activity/create-activity.wxml-->
<view class="container">
  <view class="form">
    <!-- Title -->
    <view class="form-item">
      <text class="label">活动标题</text>
      <input
        class="input"
        placeholder="给活动起个吸引人的标题吧"
        value="{{title}}"
        maxlength="30"
        bindinput="onTitleInput"
      />
      <text class="char-count">{{title.length}}/30</text>
    </view>

    <!-- Description -->
    <view class="form-item">
      <text class="label">活动描述</text>
      <textarea
        class="textarea"
        placeholder="详细描述一下活动内容、要求等"
        value="{{description}}"
        maxlength="500"
        auto-height
        bindinput="onDescriptionInput"
      />
      <text class="char-count">{{description.length}}/500</text>
    </view>

    <!-- Category -->
    <view class="form-item">
      <text class="label">活动类型</text>
      <picker
        class="picker"
        mode="selector"
        range="{{categories}}"
        range-key="name"
        value="{{categoryIndex}}"
        bindchange="onCategoryChange"
      >
        <view class="picker-value">
          <text>{{categories[categoryIndex].name}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- Subcategory -->
    <view class="form-item" wx:if="{{subcategories.length > 0}}">
      <text class="label">具体分类</text>
      <picker
        class="picker"
        mode="selector"
        range="{{subcategories}}"
        range-key="name"
        value="{{subcategoryIndex}}"
        bindchange="onSubcategoryChange"
      >
        <view class="picker-value">
          <text>{{subcategories[subcategoryIndex].name}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- DateTime -->
    <view class="form-item">
      <text class="label">活动时间</text>
      <picker
        class="picker"
        mode="date"
        value="{{datetime}}"
        bindchange="onDatetimeChange"
      >
        <picker
          class="picker-inline"
          mode="time"
          value="{{datetime}}"
          bindchange="onDatetimeChange"
        >
          <view class="picker-value">
            <text>{{datetime || '请选择时间'}}</text>
            <text class="arrow">›</text>
          </view>
        </picker>
      </picker>
    </view>

    <!-- Location -->
    <view class="form-item">
      <text class="label">活动地点</text>
      <view class="location-selector" bindtap="onChooseLocation">
        <view wx:if="{{location}}" class="location-info">
          <text class="location-name">{{location.name}}</text>
          <text class="location-address">{{location.address}}</text>
        </view>
        <view wx:else class="location-placeholder">
          <text>点击选择地点</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- Max Participants -->
    <view class="form-item">
      <text class="label">人数上限</text>
      <stepper
        value="{{maxParticipants}}"
        min="2"
        max="10"
        bindchange="onMaxParticipantsChange"
      />
    </view>

    <!-- Images -->
    <view class="form-item">
      <text class="label">活动图片（最多3张）</text>
      <view class="image-list">
        <view
          class="image-item"
          wx:for="{{images}}"
          wx:key="index"
        >
          <image class="image" src="{{item}}" mode="aspectFill"></image>
          <view
            class="image-remove"
            data-index="{{index}}"
            catchtap="onRemoveImage"
          >
            <text class="remove-icon">×</text>
          </view>
        </view>
        <view
          class="image-add"
          wx:if="{{images.length < 3}}"
          bindtap="onChooseImage"
        >
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Submit Button -->
  <view class="submit-wrapper">
    <button
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '发布中...' : '发布活动'}}
    </button>
  </view>

  <!-- 隐私协议弹窗 -->
  <view class="privacy-mask" wx:if="{{showPrivacy}}">
    <view class="privacy-dialog">
      <view class="privacy-title">隐私保护提示</view>
      <view class="privacy-content">
        <text>在使用位置服务前，请阅读并同意</text>
        <text class="privacy-link" bindtap="openPrivacyContract">《心动卡片隐私保护指引》</text>
      </view>
      <view class="privacy-buttons">
        <button class="privacy-btn reject" bindtap="handleRejectPrivacy">拒绝</button>
        <button class="privacy-btn agree" id="agree-btn" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="handleAgreePrivacy">同意</button>
      </view>
    </view>
  </view>
</view>
