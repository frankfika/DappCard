/* pages/create-activity/create-activity.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding-bottom: 140rpx;
}

.form {
  padding: 20rpx 30rpx;
}

.form-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #4a3f3a;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #4a3f3a;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.textarea {
  width: 100%;
  font-size: 28rpx;
  color: #4a3f3a;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  min-height: 200rpx;
}

.char-count {
  position: absolute;
  right: 30rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.picker {
  width: 100%;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #4a3f3a;
}

.arrow {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
}

.location-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-name {
  font-size: 28rpx;
  color: #4a3f3a;
  margin-bottom: 8rpx;
}

.location-address {
  font-size: 24rpx;
  color: #999;
}

.location-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #999;
}

stepper {
  margin-top: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: #ff4444;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #fff;
  font-size: 32rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #ddd;
}

.submit-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.6;
}
