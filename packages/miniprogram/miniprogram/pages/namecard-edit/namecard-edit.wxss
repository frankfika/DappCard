/* miniprogram/pages/namecard-edit/namecard-edit.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding: 30rpx;
  padding-bottom: 150rpx;
}

/* Section */
.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* Theme Selector */
.theme-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.theme-item {
  position: relative;
  flex: 0 0 calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.theme-item.active {
  border-color: #ff8a80;
  background: #fef7f4;
}

.theme-preview {
  width: 100%;
  height: 120rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.theme-label {
  font-size: 28rpx;
  color: #4a3f3a;
}

.theme-check {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff8a80;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* Cover Upload */
.cover-upload {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #cccccc;
  border-radius: 16rpx;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999999;
}

/* Motto Input */
.motto-input {
  width: 100%;
  min-height: 150rpx;
  font-size: 30rpx;
  color: #4a3f3a;
  background: #fef7f4;
  padding: 20rpx;
  border-radius: 12rpx;
}

/* Social Links */
.add-btn {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.social-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.social-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fef7f4;
  border-radius: 12rpx;
}

.social-info {
  flex: 1;
}

.social-platform {
  font-size: 28rpx;
  font-weight: 500;
  color: #ff8a80;
  margin-bottom: 8rpx;
}

.social-link {
  font-size: 26rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-btn {
  font-size: 26rpx;
  color: #ff8a80;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ff8a80;
  border-radius: 20rpx;
}

.empty-tip {
  text-align: center;
  font-size: 28rpx;
  color: #999999;
  padding: 60rpx 0;
}

/* Save Button */
.save-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx 0;
  box-shadow: 0 -4rpx 20rpx rgba(255, 138, 128, 0.2);
}
