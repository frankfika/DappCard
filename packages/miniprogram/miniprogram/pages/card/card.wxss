/* Minimalist & Native WeChat UI */
.page {
  height: 100vh;
  background: #ffffff;
  color: #333;
  display: flex;
  flex-direction: column;
}

/* Onboarding */
.onboarding { flex: 1; display: flex; flex-direction: column; padding: 60rpx 40rpx calc(60rpx + env(safe-area-inset-bottom)); overflow-y: auto; }
.onboarding-content { width: 100%; max-width: 100%; }
.onboarding-title { font-size: 52rpx; font-weight: 700; margin-bottom: 16rpx; color: #111; }
.onboarding-subtitle { font-size: 30rpx; color: #888; margin-bottom: 60rpx; }

.input, .textarea {
  background: #f7f7f7;
  border-radius: 24rpx;
  padding: 32rpx;
  color: #111;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  width: 100%;
}
.textarea { height: 200rpx; }

.section-title { font-size: 26rpx; font-weight: 600; color: #999; margin: 40rpx 0 24rpx; }

.tag-grid, .option-list { display: flex; flex-wrap: wrap; gap: 20rpx; }
.tag-item, .option-item {
  padding: 14rpx 36rpx;
  border-radius: 100rpx;
  background: #f7f7f7;
  font-size: 28rpx;
  color: #333;
}
.tag-active, .option-active { background: #111; color: #fff; }

.btn-primary { background: #111; color: #fff; border-radius: 100rpx; font-size: 32rpx; font-weight: 600; height: 96rpx; line-height: 96rpx; margin-top: 60rpx; }
.btn-primary::after { border: none; }

/* Card */
.card-container { flex: 1; display: flex; flex-direction: column; position: relative; }
.card-scroll { flex: 1; width: 100%; }
.card-inner { padding: 40rpx 40rpx 0; }

.profile-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 48rpx; }
.avatar { width: 180rpx; height: 180rpx; border-radius: 50%; background: #f7f7f7; margin-bottom: 24rpx; }
.avatar-placeholder { background: #e0e0e0; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 80rpx; font-weight: bold; }
.profile-name { font-size: 48rpx; font-weight: 700; margin-bottom: 8rpx; color: #111; }
.profile-handle { font-size: 28rpx; color: #888; }

.tags-wrap { display: flex; flex-wrap: wrap; justify-content: center; gap: 16rpx; margin-bottom: 48rpx; }
.profile-tag { padding: 10rpx 28rpx; border-radius: 100rpx; background: #f0f4ff; font-size: 24rpx; font-weight: 500; color: #2563eb; }

.bio-card, .looking-card, .verified-card, .highlight-item, .moment-preview {
  background: #f9f9f9;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.bio-card { padding: 40rpx 32rpx; }
.bio-text { font-size: 30rpx; line-height: 1.6; color: #333; text-align: center; }

.looking-card { padding: 32rpx; display: flex; align-items: center; gap: 24rpx; }
.looking-icon { width: 72rpx; height: 72rpx; border-radius: 20rpx; background: #fff; color: #111; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.looking-content { flex: 1; }
.looking-label { font-size: 24rpx; color: #999; margin-bottom: 4rpx; }
.looking-value { font-size: 30rpx; font-weight: 600; color: #111; }

.verified-card { padding: 32rpx; display: flex; justify-content: space-around; }
.verified-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.verified-icon { width: 80rpx; height: 80rpx; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.verified-label { font-size: 22rpx; color: #999; }

.highlights-wrap { margin-bottom: 24rpx; }
.highlight-item { padding: 24rpx 32rpx; display: flex; align-items: center; gap: 24rpx; }
.highlight-icon { width: 64rpx; height: 64rpx; border-radius: 20rpx; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.highlight-title { font-size: 28rpx; font-weight: 500; color: #111; }

.moment-preview { padding: 32rpx; }
.moment-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.moment-icon { font-size: 28rpx; }
.moment-title { font-size: 26rpx; font-weight: 600; color: #666; }
.moment-content { font-size: 30rpx; line-height: 1.6; color: #111; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.bottom-space { height: 200rpx; }

/* Action Bar */
.action-bar { position: fixed; left: 0; right: 0; bottom: 0; padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom)); background: #ffffff; border-top: 1rpx solid #f0f0f0; display: flex; gap: 24rpx; z-index: 10; }
.action-bar .btn-primary, .btn-secondary { flex: 1; border-radius: 100rpx; font-size: 32rpx; font-weight: 600; height: 96rpx; line-height: 96rpx; margin: 0; }
.action-bar .btn-primary { background: #111; color: #fff; }
.action-bar .btn-secondary { background: #f7f7f7; color: #111; }
.action-bar .btn-cta { background: #2563eb; color: #fff; }
.btn-secondary::after { border: none; }

/* Modal New Design */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 50; display: flex; align-items: flex-end; }
.modal-sheet { background: #ffffff; border-radius: 40rpx 40rpx 0 0; width: 100%; height: 88vh; display: flex; flex-direction: column; overflow: hidden; }

.modal-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  background: #ffffff;
  position: relative;
  z-index: 10;
}
.modal-title { font-size: 36rpx; font-weight: 800; color: #111; }
.modal-actions { display: flex; align-items: center; gap: 24rpx; }
.modal-close { font-size: 30rpx; color: #999; font-weight: 600; padding: 10rpx; }
.modal-save-btn { background: #111; color: #fff; padding: 16rpx 40rpx; border-radius: 100rpx; font-size: 28rpx; font-weight: 700; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }

.modal-body {
  flex: 1;
  min-height: 0;
  background: #ffffff;
}

.edit-section {
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f7f7f7;
}
.edit-section:last-child { border-bottom: none; }

.edit-input, .edit-textarea {
  background: #f7f7f7;
  border-radius: 24rpx;
  padding: 32rpx;
  color: #111;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}
.edit-input.font-bold { font-weight: 800; font-size: 40rpx; }
.edit-input-handle { font-size: 28rpx; color: #666; padding: 24rpx 32rpx; }
.edit-textarea { height: 180rpx; line-height: 1.5; font-size: 30rpx; }

.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.section-title-new { font-size: 32rpx; font-weight: 800; color: #111; margin-bottom: 24rpx; display: block; }
.section-subtitle-new { font-size: 26rpx; color: #999; font-weight: 600; }

.h-scroll { width: calc(100% + 80rpx); white-space: nowrap; margin: 0 -40rpx; padding: 0 40rpx; box-sizing: border-box; }
.h-scroll-inner { display: inline-flex; gap: 16rpx; padding-right: 80rpx; }

.pill {
  display: inline-block;
  padding: 16rpx 36rpx;
  border-radius: 100rpx;
  background: #f7f7f7;
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  transition: all 0.2s;
}
.pill-active { background: #111; color: #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }

.pill-card {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  background: #f7f7f7;
  font-size: 28rpx;
  font-weight: 700;
  color: #444;
}
.pill-card-active { background: #111; color: #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }

.custom-tag-row { display: flex; align-items: center; gap: 16rpx; margin-top: 32rpx; }
.custom-tag-input { flex: 1; background: #f7f7f7; border-radius: 100rpx; padding: 20rpx 32rpx; font-size: 28rpx; color: #111; }
.custom-tag-btn { padding: 20rpx 40rpx; border-radius: 100rpx; background: #f7f7f7; font-size: 28rpx; color: #999; font-weight: 700; }
.custom-tag-btn-active { background: #111; color: #fff; }

.bottom-space-sm { height: 120rpx; }
