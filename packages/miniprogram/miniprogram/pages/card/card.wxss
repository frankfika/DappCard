/* Complete rewrite for Premium Modern UI */
.page {
  height: 100vh;
  background: #f4f5f7;
  color: #111;
  display: flex;
  flex-direction: column;
}

/* Onboarding */
.onboarding { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40rpx; overflow-y: auto; }
.onboarding-content { width: 100%; max-width: 600rpx; }
.onboarding-title { font-size: 56rpx; font-weight: 900; margin-bottom: 16rpx; text-align: center; color: #111; letter-spacing: -1rpx; }
.onboarding-subtitle { font-size: 32rpx; color: #666; margin-bottom: 64rpx; text-align: center; font-weight: 500; }

.input, .textarea {
  background: #fff;
  border: 2rpx solid transparent;
  border-radius: 32rpx;
  padding: 32rpx;
  color: #111;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
  width: 100%;
}
.textarea { height: 200rpx; }

.section-title { font-size: 24rpx; font-weight: 800; color: #999; text-transform: uppercase; letter-spacing: 2rpx; margin: 40rpx 0 20rpx; padding-left: 8rpx; }

.tag-grid, .option-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag-item, .option-item {
  padding: 16rpx 32rpx;
  border-radius: 100rpx;
  background: #fff;
  font-size: 28rpx;
  color: #555;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  border: 2rpx solid transparent;
}
.tag-active, .option-active { background: #111; color: #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15); }

.btn-primary { background: #111; color: #fff; border-radius: 40rpx; font-size: 32rpx; font-weight: 800; height: 112rpx; line-height: 112rpx; margin-top: 64rpx; border: none; box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.15); }
.btn-primary::after { border: none; }

/* Card */
.card-container { flex: 1; display: flex; flex-direction: column; position: relative; }
.card-scroll { flex: 1; padding: 0 40rpx; min-height: 0; width: 100%; }
.card-inner { padding-top: 40rpx; }

.profile-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; }
.avatar { width: 200rpx; height: 200rpx; border-radius: 64rpx; background: #fff; border: 8rpx solid #fff; box-shadow: 0 20rpx 48rpx rgba(0,0,0,0.08); margin-bottom: 32rpx; }
.profile-name { font-size: 56rpx; font-weight: 900; margin-bottom: 8rpx; text-align: center; color: #111; letter-spacing: -1rpx; }
.profile-handle { font-size: 32rpx; color: #666; font-weight: 600; }

.tags-wrap { display: flex; flex-wrap: wrap; justify-content: center; gap: 16rpx; margin-bottom: 40rpx; }
.profile-tag { padding: 12rpx 28rpx; border-radius: 100rpx; background: #fff; font-size: 26rpx; font-weight: 700; color: #111; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }

.bio-card, .looking-card, .verified-card, .highlight-item, .moment-preview {
  background: #fff;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04);
  border: none;
}

.bio-card { padding: 40rpx; }
.bio-text { font-size: 32rpx; line-height: 1.6; color: #222; text-align: center; font-weight: 500; }

.looking-card { padding: 32rpx 40rpx; display: flex; align-items: center; gap: 32rpx; }
.looking-icon { width: 80rpx; height: 80rpx; border-radius: 24rpx; background: #111; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15); }
.looking-content { flex: 1; }
.looking-label { font-size: 22rpx; color: #888; font-weight: 800; text-transform: uppercase; letter-spacing: 2rpx; margin-bottom: 8rpx; }
.looking-value { font-size: 32rpx; font-weight: 800; color: #111; }

.verified-card { padding: 32rpx; display: flex; justify-content: space-around; }
.verified-item { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.verified-icon { width: 88rpx; height: 88rpx; border-radius: 28rpx; background: #f4f5f7; display: flex; align-items: center; justify-content: center; font-size: 44rpx; }
.verified-label { font-size: 20rpx; color: #888; font-weight: 800; text-transform: uppercase; letter-spacing: 2rpx; }

.highlights-wrap { margin-bottom: 24rpx; }
.highlight-item { padding: 24rpx 32rpx; display: flex; align-items: center; gap: 24rpx; }
.highlight-icon { width: 72rpx; height: 72rpx; border-radius: 24rpx; background: #f4f5f7; display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0;}
.highlight-title { font-size: 28rpx; font-weight: 700; color: #111; }

.moment-preview { padding: 32rpx 40rpx; position: relative; overflow: hidden; }
.moment-preview::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 8rpx; background: #111; }
.moment-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.moment-icon { font-size: 32rpx; }
.moment-title { font-size: 26rpx; font-weight: 800; color: #666; }
.moment-content { font-size: 30rpx; line-height: 1.6; color: #111; font-weight: 600; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.bottom-space { height: 200rpx; }

/* Action Bar */
.action-bar { position: fixed; left: 0; right: 0; bottom: calc(112rpx + env(safe-area-inset-bottom)); padding: 24rpx 40rpx; background: linear-gradient(to top, #f4f5f7 40%, rgba(244, 245, 247, 0.8) 80%, transparent); display: flex; gap: 24rpx; z-index: 10; }
.action-bar .btn-primary, .btn-secondary { flex: 1; background: #fff; color: #111; border-radius: 40rpx; font-size: 32rpx; font-weight: 800; height: 112rpx; line-height: 112rpx; border: none; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); margin: 0; }
.action-bar .btn-primary { background: #111; color: #fff; box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.2); }
.action-bar .btn-cta { background: linear-gradient(135deg, #111, #333); animation: pulse-glow 2s infinite; }
@keyframes pulse-glow { 0% { box-shadow: 0 0 0 0 rgba(17, 17, 17, 0.4); } 70% { box-shadow: 0 0 0 24rpx rgba(17, 17, 17, 0); } 100% { box-shadow: 0 0 0 0 rgba(17, 17, 17, 0); } }
.btn-secondary::after { border: none; }

/* Modal */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.2); backdrop-filter: blur(24rpx); z-index: 50; display: flex; align-items: flex-end; }
.modal-sheet { background: #f4f5f7; border-radius: 56rpx 56rpx 0 0; width: 100%; height: 90vh; display: flex; flex-direction: column; box-shadow: 0 -16rpx 64rpx rgba(0,0,0,0.15); }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 40rpx 40rpx 24rpx; }
.modal-close { width: 72rpx; height: 72rpx; background: #e8e9ec; border-radius: 36rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #555; font-weight: 800; }
.modal-title { font-size: 36rpx; font-weight: 900; color: #111; letter-spacing: -0.5rpx; }
.modal-save { background: #111; color: #fff; padding: 0 40rpx; height: 72rpx; line-height: 72rpx; border-radius: 36rpx; font-size: 28rpx; font-weight: 800; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15); }
.modal-body { padding: 16rpx 40rpx calc(60rpx + env(safe-area-inset-bottom)); flex: 1; min-height: 0; }

/* Custom Tag */
.custom-tag-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.custom-tag-input { flex: 1; background: #fff; border: 2rpx solid transparent; border-radius: 32rpx; padding: 24rpx 32rpx; color: #111; font-size: 28rpx; font-weight: 600; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); }
.custom-tag-btn { padding: 0 36rpx; background: #e8e9ec; color: #999; border-radius: 32rpx; font-size: 28rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.custom-tag-btn-active { background: #111; color: #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15); }
.profile-tag-add { color: #999; background: transparent; border: 2rpx dashed #ccc; box-shadow: none; }
