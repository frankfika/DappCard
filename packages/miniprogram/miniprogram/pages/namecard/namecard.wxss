/* miniprogram/pages/namecard/namecard.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 150rpx;
}

/* Theme Styles */
.theme-romantic {
  background: linear-gradient(180deg, #ff8a80 0%, #f48fb1 50%, #fef7f4 100%);
}

.theme-minimal {
  background: linear-gradient(180deg, #ffffff 0%, #f5f5f5 100%);
}

.theme-nature {
  background: linear-gradient(180deg, #81c784 0%, #aed581 50%, #f1f8e9 100%);
}

.theme-ocean {
  background: linear-gradient(180deg, #4fc3f7 0%, #81d4fa 50%, #e1f5fe 100%);
}

.theme-sunset {
  background: linear-gradient(180deg, #ff9800 0%, #ffb74d 50%, #fff3e0 100%);
}

/* Cover Section */
.namecard-cover {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.3), transparent);
}

.avatar-wrapper {
  position: absolute;
  bottom: -80rpx;
  left: 50%;
  transform: translateX(-50%);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 8rpx solid #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* User Info */
.user-info {
  text-align: center;
  padding: 100rpx 40rpx 40rpx;
}

.nickname {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.theme-minimal .nickname {
  color: #4a3f3a;
  text-shadow: none;
}

.bio {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.theme-minimal .bio {
  color: #666666;
}

/* Motto Section */
.motto-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.motto-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.motto-text {
  flex: 1;
  font-size: 30rpx;
  color: #4a3f3a;
  line-height: 1.6;
  font-style: italic;
}

/* Interests Section */
.interests-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 24rpx;
}

.interests-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.interest-tag {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

/* Social Section */
.social-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.social-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.social-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fef7f4;
  border-radius: 12rpx;
}

.social-platform {
  font-size: 28rpx;
  font-weight: 500;
  color: #ff8a80;
}

.social-link {
  font-size: 26rpx;
  color: #666666;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Action Buttons */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
  text-align: center;
}

.action-btn::after {
  border: none;
}

.edit-btn {
  background: #ffffff;
  color: #ff8a80;
  border: 2rpx solid #ff8a80;
}
