<!--miniprogram/pages/namecard/namecard.wxml-->
<view class="container {{themeClass}}">
  <!-- Cover Section -->
  <view class="namecard-cover">
    <image
      wx:if="{{namecard.coverImage}}"
      class="cover-image"
      src="{{namecard.coverImage}}"
      mode="aspectFill"
    ></image>
    <view class="cover-overlay"></view>

    <!-- Avatar -->
    <view class="avatar-wrapper">
      <image
        class="avatar"
        src="{{namecard.avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
      ></image>
    </view>
  </view>

  <!-- User Info -->
  <view class="user-info">
    <view class="nickname">{{namecard.nickname || '未设置昵称'}}</view>
    <view class="bio">{{namecard.bio || '这个人很懒，什么都没留下'}}</view>
  </view>

  <!-- On-Chain Profile -->
  <view class="onchain-section" wx:if="{{hasWalletAddress}}">
    <view class="section-title">
      <text class="onchain-icon">⛓</text>
      <text>链上名片</text>
    </view>

    <view class="onchain-loading" wx:if="{{isLoadingOnChain}}">
      <view class="loading-dot"></view>
      <text>正在读取链上数据...</text>
    </view>

    <view class="onchain-content" wx:if="{{!isLoadingOnChain && onChainProfile}}">
      <view class="onchain-empty" wx:if="{{onChainProfile.empty}}">
        <text>暂无链上名片数据</text>
        <text class="onchain-hint">在 Web 端保存名片到链上后即可查看</text>
      </view>

      <view class="onchain-error" wx:if="{{onChainProfile.error}}">
        <text>读取链上数据失败</text>
        <text class="onchain-hint">请检查网络连接后重试</text>
      </view>

      <view class="onchain-data" wx:if="{{onChainProfile.loaded && !onChainProfile.empty && !onChainProfile.error}}">
        <view class="onchain-row">
          <text class="onchain-label">存储网络</text>
          <text class="onchain-value">Base Sepolia</text>
        </view>
        <view class="onchain-row">
          <text class="onchain-label">IPFS 哈希</text>
          <text class="onchain-value onchain-hash">{{onChainProfile.ipfsHash}}</text>
        </view>
        <view class="onchain-row" wx:if="{{onChainProfile.content && onChainProfile.content.data}}">
          <text class="onchain-label">链上内容</text>
          <text class="onchain-value">已同步</text>
        </view>
        <view class="onchain-verify" bindtap="handleOpenOnChainDetail">
          <text>查看详情 ></text>
        </view>
      </view>
    </view>
  </view>

  <view class="onchain-section onchain-bind" wx:if="{{isOwn && !hasWalletAddress}}">
    <view class="onchain-bind-content" bindtap="handleBindWallet">
      <text class="onchain-icon">⛓</text>
      <text class="onchain-bind-text">绑定钱包地址，开启链上存储</text>
      <text class="onchain-bind-arrow">></text>
    </view>
  </view>

  <!-- Motto -->
  <view class="motto-section" wx:if="{{namecard.motto}}">
    <view class="motto-icon">💭</view>
    <view class="motto-text">{{namecard.motto}}</view>
  </view>

  <!-- Interests -->
  <view class="interests-section" wx:if="{{namecard.interests && namecard.interests.length > 0}}">
    <view class="section-title">兴趣爱好</view>
    <view class="interests-grid">
      <view class="interest-tag" wx:for="{{namecard.interests}}" wx:key="index">
        {{item}}
      </view>
    </view>
  </view>

  <!-- Social Links -->
  <view class="social-section" wx:if="{{namecard.socialLinks && namecard.socialLinks.length > 0}}">
    <view class="section-title">社交媒体</view>
    <view class="social-list">
      <view
        class="social-item"
        wx:for="{{namecard.socialLinks}}"
        wx:key="index"
        data-link="{{item.link}}"
        bindtap="handleSocialLink"
      >
        <view class="social-platform">{{item.platform}}</view>
        <view class="social-link">{{item.link}}</view>
      </view>
    </view>
  </view>

  <!-- Action Buttons -->
  <view class="action-buttons">
    <button class="action-btn share-btn" bindtap="handleShare" open-type="share">
      <text>分享名片</text>
    </button>

    <button class="action-btn" bindtap="handleSaveImage" wx:if="{{!isOwn}}">
      <text>保存图片</text>
    </button>

    <button class="action-btn edit-btn" bindtap="handleEdit" wx:if="{{isOwn}}">
      <text>编辑名片</text>
    </button>
  </view>
</view>
