.page {
  height: 100vh;
  background: #fafafa;
  color: #111;
  display: flex;
  flex-direction: column;
}
.page-header {
  padding: 40rpx 48rpx 24rpx;
  flex-shrink: 0;
}
.page-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  color: #111;
}
.page-body {
  flex: 1;
  padding: 0 48rpx;
  min-height: 0;
}
.section {
  margin-bottom: 40rpx;
}
.section-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  margin-bottom: 20rpx;
}
.label-icon {
  font-size: 28rpx;
}
.identity-card {
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.identity-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.identity-icon {
  font-size: 48rpx;
}
.identity-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  color: #111;
}
.identity-desc {
  font-size: 24rpx;
  color: #888;
}
.identity-status {
  flex-shrink: 0;
}
.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  font-weight: 700;
  color: #888;
}
.status-complete {
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}
.entry-card {
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.entry-main {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.entry-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #f5f5f5;
}
.entry-icon-primary {
  background: #111;
  color: #fff;
}
.entry-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  color: #111;
}
.entry-desc {
  font-size: 24rpx;
  color: #888;
}
.entry-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #888;
}
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.grid-card {
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.grid-card-disabled {
  opacity: 0.6;
}
.grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 20rpx;
}
.grid-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  color: #111;
}
.grid-desc {
  font-size: 22rpx;
  color: #888;
  line-height: 1.4;
}
