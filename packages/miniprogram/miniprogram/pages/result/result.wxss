/**
 * 结果页样式 - 温馨浪漫风格
 */

.container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fef7f4 0%, #fff0ed 50%, #fce4ec 100%);
}

.result-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 56rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 138, 128, 0.2);
  border: 1rpx solid rgba(255, 138, 128, 0.1);
  width: 100%;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 28rpx;
  animation: bounce 1s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a3f3a;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8b7e78;
  margin-bottom: 48rpx;
}

.stats {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #fff8f7 0%, #fef5f3 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 138, 128, 0.1);
}

.stat-item {
  text-align: center;
  margin: 0 40rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ff8a80;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8b7e78;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 128, 0.35);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 138, 128, 0.25);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid #f8bbd9;
  color: #f48fb1;
}

.btn-outline:active {
  background: #fff8f7;
}
