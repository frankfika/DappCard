<!-- 结果页面 - 完成所有卡片后显示 -->
<view class="container">
  <view class="result-card">
    <view class="icon">🎉</view>
    <view class="title">恭喜完成！</view>
    <view class="subtitle">你们完成了「{{modeName}}」的全部卡片</view>

    <view class="stats">
      <view class="stat-item">
        <view class="stat-value">{{totalCount}}</view>
        <view class="stat-label">完成卡片</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{favoriteCount}}</view>
        <view class="stat-label">收藏卡片</view>
      </view>
    </view>

    <view class="actions">
      <button class="btn btn-primary" bindtap="playAgain">再玩一次</button>
      <button class="btn btn-outline" bindtap="goHome">返回首页</button>
    </view>
  </view>
</view>
