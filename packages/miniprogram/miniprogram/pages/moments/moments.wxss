/* miniprogram/pages/moments/moments.wxss */
page {
  background-color: #fef7f4;
}

.moments-container {
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* Header */
.page-header {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
}

/* Posts Feed */
.posts-feed {
  padding: 20rpx;
}

.post-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 138, 128, 0.1);
}

/* User Info */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #4a3f3a;
  margin-bottom: 8rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

/* Content */
.post-content {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #4a3f3a;
  word-break: break-all;
}

/* Images */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.post-image {
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.post-image-1 {
  width: 100%;
  height: 400rpx;
}

.post-image-2 {
  width: calc(50% - 5rpx);
  height: 300rpx;
}

.post-image-3 {
  width: calc(33.33% - 7rpx);
  height: 200rpx;
}

/* Activity Tag */
.activity-tag {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff0ed;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.tag-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tag-text {
  font-size: 26rpx;
  color: #ff8a80;
}

/* Interaction Bar */
.interaction-bar {
  display: flex;
  gap: 60rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.interaction-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.interaction-item .icon {
  font-size: 36rpx;
  transition: transform 0.2s;
}

.interaction-item .icon.liked {
  animation: like-bounce 0.4s ease;
}

@keyframes like-bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); }
}

.interaction-item .count {
  font-size: 26rpx;
  color: #666;
}

/* Comments Section */
.comments-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.comment-item {
  padding: 16rpx 0;
  font-size: 26rpx;
  line-height: 1.5;
}

.comment-user {
  color: #ff8a80;
  font-weight: bold;
}

.comment-text {
  color: #4a3f3a;
}

.add-comment {
  margin-top: 16rpx;
}

.comment-input {
  width: 100%;
  padding: 16rpx 20rpx;
  background-color: #fef7f4;
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Loading */
.loading-state {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 128, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background-color: white;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4a3f3a;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  padding: 30rpx 40rpx;
  overflow-y: auto;
}

/* Content Input */
.content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background-color: #fef7f4;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* Image Upload */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 30rpx;
}

.upload-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fef7f4;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

/* Activity Selection */
.activity-select {
  margin-top: 30rpx;
}

.select-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.picker-input {
  padding: 24rpx 30rpx;
  background-color: #fef7f4;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #4a3f3a;
}

/* Modal Footer */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel,
.btn-submit {
  flex: 1;
  padding: 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.btn-submit {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: white;
}

.btn-submit[disabled] {
  opacity: 0.5;
}
