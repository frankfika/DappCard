<view class="page">
  <view class="page-header">
    <view class="page-title">发现搭子</view>
    <view class="header-actions">
      <view class="icon-btn" bindtap="openCreate">
        <text class="icon-btn-text">+</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="page-body">
    <!-- Category Pills -->
    <scroll-view scroll-x class="category-scroll" show-scrollbar="{{false}}">
      <view class="category-list">
        <view class="category-pill {{selectedCategory === null ? 'category-pill-active' : ''}}" bindtap="selectCategory" data-cat="">全部</view>
        <view wx:for="{{companionTypes}}" wx:key="id" class="category-pill {{selectedCategory === item.id ? 'category-pill-active' : ''}}" bindtap="selectCategory" data-cat="{{item.id}}" style="{{selectedCategory === item.id ? 'background:' + item.color + ';color:#fff;' : ''}}">{{item.icon}} {{item.name}}</view>
      </view>
    </scroll-view>

    <!-- Activity Cards -->
    <view class="activity-list">
      <view wx:for="{{activities}}" wx:key="id" wx:for-item="activity" class="activity-card {{!selectedCategory || activity.category === selectedCategory ? '' : 'hidden'}}">
        <view class="activity-main">
          <image wx:if="{{activity.avatar}}" class="activity-avatar" src="{{activity.avatar}}" mode="aspectFill" />
          <view wx:else class="activity-avatar activity-avatar-placeholder"></view>
          <view class="activity-info">
            <view class="activity-meta">
              <view class="activity-badge" style="background: {{activity._categoryColor}}">{{activity._categoryIcon}} {{activity._categoryName}}</view>
              <text class="activity-creator">{{activity.creator}}</text>
            </view>
            <view class="activity-title">{{activity.title}}</view>
            <view wx:if="{{activity.description}}" class="activity-desc">{{activity.description}}</view>
            <view class="activity-details">
              <text class="detail-item">📍 {{activity.location}}</text>
              <text class="detail-item">⏰ {{activity.time}}</text>
              <text class="detail-item">👥 {{activity.participants}}/{{activity.maxParticipants}}</text>
            </view>
          </view>
        </view>
        <view class="activity-action">
          <button wx:if="{{!activity.joined}}" class="join-btn" bindtap="joinActivity" data-id="{{activity.id}}">加入</button>
          <button wx:else class="leave-btn" bindtap="leaveActivity" data-id="{{activity.id}}">已加入</button>
        </view>
      </view>
    </view>
    <view class="bottom-space" />
  </scroll-view>

  <!-- Create Modal -->
  <view wx:if="{{showCreate}}" class="modal-overlay" bindtap="closeCreate">
    <view class="modal-sheet" catchtap="noop">
      <view class="modal-header">
        <view class="modal-close" bindtap="closeCreate">✕</view>
        <view class="modal-title">创建活动</view>
        <view class="modal-save" bindtap="submitCreate">发布</view>
      </view>
      <scroll-view scroll-y class="modal-body">
        <input class="input" placeholder="活动标题" placeholder-style="color: #bbb;" value="{{createTitle}}" bindinput="onCreateTitle" />
        <textarea class="textarea" placeholder="活动描述" placeholder-style="color: #bbb;" value="{{createDesc}}" bindinput="onCreateDesc" />
        <input class="input" placeholder="地点" placeholder-style="color: #bbb;" value="{{createLocation}}" bindinput="onCreateLocation" />
        <input class="input" placeholder="时间" placeholder-style="color: #bbb;" value="{{createTime}}" bindinput="onCreateTime" />
        <input class="input" placeholder="人数上限" placeholder-style="color: #bbb;" type="number" value="{{createMaxParticipants}}" bindinput="onCreateMax" />
        <view class="section-title">分类</view>
        <view class="category-grid">
          <view wx:for="{{companionTypes}}" wx:key="id" class="category-select {{createCategory === item.id ? 'category-select-active' : ''}}" bindtap="onCreateCategory" data-cat="{{item.id}}" style="{{createCategory === item.id ? 'background:' + item.color + ';color:#fff;' : ''}}">{{item.icon}} {{item.name}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
