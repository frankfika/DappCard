.page {
  height: 100vh;
  background: #fafafa;
  color: #111;
  display: flex;
  flex-direction: column;
}
.page-header {
  padding: 32rpx 40rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}
.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #111;
}
.header-actions {
  display: flex;
  gap: 16rpx;
}
.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.icon-btn-text {
  font-size: 36rpx;
  font-weight: 300;
  color: #111;
}
.page-body {
  flex: 1;
  padding: 0 40rpx;
  min-height: 0;
}
.category-scroll {
  margin-bottom: 32rpx;
}
.category-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}
.category-pill {
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid #f0f0f0;
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.category-pill-active {
  background: #111;
  color: #fff;
  border-color: #111;
}
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.activity-card {
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.activity-main {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}
.activity-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}
.activity-info {
  flex: 1;
  min-width: 0;
}
.activity-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}
.activity-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
}
.activity-creator {
  font-size: 22rpx;
  color: #888;
}
.activity-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  line-height: 1.3;
  color: #111;
}
.activity-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.activity-details {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.detail-item {
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
}
.activity-action {
  display: flex;
  justify-content: flex-end;
}
.join-btn {
  background: #111;
  color: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  line-height: 1.5;
  border: none;
}
.join-btn::after { border: none; }
.leave-btn {
  background: #f5f5f5;
  color: #888;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  line-height: 1.5;
  border: none;
}
.leave-btn::after { border: none; }
.bottom-space {
  height: 160rpx;
}

/* Modal */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 50;
  display: flex;
  align-items: flex-end;
}
.modal-sheet {
  background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.08);
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.modal-close {
  font-size: 32rpx;
  color: #999;
  width: 60rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
}
.modal-save {
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
  width: 80rpx;
  text-align: right;
}
.modal-body {
  padding: 32rpx 40rpx;
  flex: 1;
  min-height: 0;
}
.input, .textarea {
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  color: #111;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}
.textarea {
  height: 180rpx;
}
.section-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  margin: 28rpx 0 16rpx;
}
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.category-select {
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  border: 1rpx solid #eee;
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
}
.category-select-active {
  border-color: transparent;
}
.hidden {
  display: none;
}
