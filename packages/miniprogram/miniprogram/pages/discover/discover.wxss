/* pages/discover/discover.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* Search Bar */
.search-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #4a3f3a;
}

/* Category Icons Row */
.category-scroll {
  white-space: nowrap;
  background-color: #fff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 15rpx;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #ffe8e5;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #4a3f3a;
  white-space: nowrap;
}

.category-item.active .category-name {
  color: #ff8a80;
  font-weight: 600;
}

/* Location Filter */
.location-filter {
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.active {
  background-color: #ff8a80;
  color: #fff;
  font-weight: 600;
}

/* Activity Feed */
.activity-feed {
  padding: 0 30rpx;
}

.loading-wrapper {
  padding: 40rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
  line-height: 1;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.no-more {
  padding: 40rpx 0;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #999;
}

/* Floating Action Button */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 128, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
  line-height: 1;
}
