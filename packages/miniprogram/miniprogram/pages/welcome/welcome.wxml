<!-- 欢迎页 - 3步引导 -->
<view class="container">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="glow glow-1"></view>
    <view class="glow glow-2"></view>
  </view>

  <!-- 主内容 -->
  <view class="content {{show ? 'show' : ''}}">
    <!-- Logo区域 -->
    <view class="logo-section">
      <view class="logo-container">
        <view class="logo-shape">
          <view class="shape-inner"></view>
        </view>
      </view>
    </view>

    <!-- 标题 -->
    <view class="title-section">
      <view class="title-label">COUPLE CARDS</view>
      <view class="title">{{t.welcome.title}}</view>
    </view>

    <!-- 引导 Swiper -->
    <swiper class="guide-swiper" indicator-dots="{{false}}" autoplay="{{false}}" bindchange="onSwiperChange" current="{{currentStep}}">
      <swiper-item wx:for="{{steps}}" wx:key="index">
        <view class="step-content">
          <text class="step-icon">{{item.icon}}</text>
          <text class="step-title">{{item.title}}</text>
          <text class="step-desc">{{item.desc}}</text>
        </view>
      </swiper-item>
    </swiper>

    <!-- 步骤指示器 -->
    <view class="step-dots">
      <view class="dot {{currentStep === index ? 'active' : ''}}" wx:for="{{steps}}" wx:key="index"></view>
    </view>

    <!-- 开始按钮 -->
    <view class="start-section">
      <view class="start-btn" bindtap="start">
        <text class="btn-text">{{currentStep === 2 ? t.welcome.start : '继续'}}</text>
        <view class="btn-icon">></view>
      </view>
      <view class="start-hint">开始你们的心动之旅</view>
    </view>
  </view>
</view>
