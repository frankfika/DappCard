/**
 * 欢迎页 - 温馨浪漫风格
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fef7f4 0%, #fff0ed 50%, #fce4ec 100%);
  position: relative;
  overflow: hidden;
}

/* ==================== 背景装饰 ==================== */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
}

.glow-1 {
  width: 600rpx;
  height: 600rpx;
  background: linear-gradient(135deg, rgba(255, 205, 210, 0.5) 0%, rgba(248, 187, 217, 0.4) 100%);
  top: -200rpx;
  right: -200rpx;
  animation: float 8s ease-in-out infinite;
}

.glow-2 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, rgba(255, 224, 178, 0.4) 0%, rgba(255, 204, 188, 0.3) 100%);
  bottom: -100rpx;
  left: -200rpx;
  animation: float 10s ease-in-out infinite reverse;
}

.bg-grid {
  display: none;
}

.dot-pattern {
  display: none;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-40rpx) scale(1.05); }
}

/* ==================== 主内容 ==================== */
.content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.6s ease;
}

.content.show {
  opacity: 1;
  transform: translateY(0);
}

/* ==================== Logo区域 ==================== */
.logo-section {
  margin-bottom: 56rpx;
}

.logo-container {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-shape {
  width: 120rpx;
  height: 120rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: heartbeat 2s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.logo-shape::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  border-radius: 32rpx;
  transform: rotate(45deg);
  box-shadow: 0 8rpx 32rpx rgba(255, 138, 128, 0.4);
}

.shape-inner {
  position: relative;
  z-index: 1;
  width: 72rpx;
  height: 72rpx;
  background: #ffffff;
  border-radius: 22rpx;
  transform: rotate(45deg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shape-inner::after {
  content: '💕';
  font-size: 32rpx;
  transform: rotate(-45deg);
}

.logo-orbit {
  position: absolute;
  width: 100%;
  height: 100%;
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.orbit-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffab91;
}

.orbit-1 {
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  background: #ff8a80;
}

.orbit-2 {
  bottom: 20rpx;
  left: 10rpx;
  background: #f48fb1;
}

.orbit-3 {
  bottom: 20rpx;
  right: 10rpx;
  background: #ce93d8;
}

/* ==================== 标题区域 ==================== */
.title-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.title-label {
  font-size: 24rpx;
  color: #f48fb1;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.title {
  font-size: 64rpx;
  font-weight: 700;
  color: #4a3f3a;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8b7e78;
  letter-spacing: 2rpx;
}

/* ==================== 引导 Swiper ==================== */
.guide-swiper {
  width: 100%;
  height: 280rpx;
  margin-bottom: 32rpx;
}

.step-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  height: 100%;
  box-sizing: border-box;
}

.step-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 12rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #8b7e78;
  text-align: center;
  line-height: 1.6;
}

.step-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 48rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fce4df;
  transition: all 0.3s ease;
}

.dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
}

/* ==================== 模式预览 ==================== */
.modes-preview {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 44rpx;
  flex-wrap: wrap;
}

.mode-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: #ffffff;
  border-radius: 50rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 138, 128, 0.12);
  animation: slideUp 0.4s ease both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.mode-indicator {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.mode-indicator.mode-dating_icebreaker {
  background: linear-gradient(135deg, #81c784 0%, #a5d6a7 100%);
}
.mode-indicator.mode-romance_spark {
  background: linear-gradient(135deg, #ff8a80 0%, #ffab91 100%);
}
.mode-indicator.mode-couple_deep {
  background: linear-gradient(135deg, #ce93d8 0%, #f48fb1 100%);
}
.mode-indicator.mode-marriage_fresh {
  background: linear-gradient(135deg, #ef9a9a 0%, #f48fb1 100%);
}

.mode-name {
  font-size: 24rpx;
  color: #8b7e78;
  white-space: nowrap;
}

/* ==================== 统计数据 ==================== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 56rpx;
  padding: 28rpx 44rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 138, 128, 0.12);
  border: 1rpx solid rgba(255, 138, 128, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff8a80;
}

.stat-label {
  font-size: 22rpx;
  color: #b5a9a3;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 44rpx;
  background: linear-gradient(180deg, transparent, #fce4df, transparent);
}

/* ==================== 开始按钮 ==================== */
.start-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 72rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  border-radius: 60rpx;
  transition: all 0.2s ease;
  box-shadow: 0 8rpx 32rpx rgba(255, 138, 128, 0.4);
}

.start-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 128, 0.3);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}

.btn-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 16rpx;
}

.start-hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #b5a9a3;
  letter-spacing: 2rpx;
}

/* ==================== 底部 ==================== */
.footer {
  margin-top: 56rpx;
}

.footer-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 138, 128, 0.08) 0%, rgba(244, 143, 177, 0.08) 100%);
  border-radius: 50rpx;
  border: 1rpx solid rgba(255, 138, 128, 0.15);
}

.badge-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  margin-right: 10rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.footer-text {
  font-size: 22rpx;
  color: #8b7e78;
}
