/* 页面 */
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #fefcfc; /* 更柔和、温暖的背景色 */
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Noto Sans CJK SC", "Source Han Sans SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #333;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.header {
  padding: 48rpx 40rpx 36rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fefdfd 100%); /* 保持柔和渐变 */
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.03); /* 更轻微的阴影 */
  margin-bottom: 36rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #2a2a2a;
  letter-spacing: -0.5rpx;
  line-height: 1.2;
}

.subtitle {
  font-size: 30rpx;
  color: #888;
  margin-top: 12rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 0 40rpx;
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 138, 128, 0.08);
  border: 1rpx solid rgba(255, 138, 128, 0.1);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #4a3f3a;
}

.search-clear {
  font-size: 28rpx;
  color: #b5a9a3;
  padding: 8rpx 16rpx;
}

/* 搜索结果 */
.search-results {
  padding: 0 40rpx;
  margin-bottom: 24rpx;
}

.search-result-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-result-item:active {
  background: #fff8f7;
}

.result-question {
  font-size: 28rpx;
  color: #4a3f3a;
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-source {
  font-size: 22rpx;
  color: #b5a9a3;
}

.search-empty {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #b5a9a3;
  font-size: 28rpx;
}

/* 每日推荐 */
.daily-section {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.daily-card {
  background: linear-gradient(135deg, #fff5f5 0%, #fce4ec 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(255, 138, 128, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 128, 0.12);
}

.daily-card:active {
  transform: scale(0.98);
}

.daily-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.daily-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.daily-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #ff8a80;
  letter-spacing: 1rpx;
}

.daily-question {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #4a3f3a;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.daily-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.daily-source {
  font-size: 22rpx;
  color: #b5a9a3;
}

.daily-tip {
  font-size: 22rpx;
  color: #f48fb1;
  font-style: italic;
}

/* 合集区 */
.collection-section {
  margin-bottom: 50rpx;
  padding: 0;
}

.section-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  display: block;
  position: sticky;
  top: 0;
  background-color: #fefcfc; /* 与页面背景色一致 */
  z-index: 10;
  padding: 16rpx 40rpx;
  transform: translateZ(0);
}

.collection-list {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.collection-item {
  width: calc(50% - 16rpx);
  height: auto;
  min-height: 260rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 36rpx;
  box-sizing: border-box;
  color: #ffffff; /* 默认白色文本，用于 preset-item */
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06); /* 更柔和的阴影 */
  transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.2s cubic-bezier(0.2, 0, 0, 1);
  background-color: #ffffff; /* source-item 的默认背景 */
  border: 1rpx solid rgba(255, 255, 255, 0.5); /* Subtle border for depth */
}

.collection-item:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03); /* 更轻微的点击阴影 */
}

.item-icon {
  font-size: 64rpx;
  line-height: 1;
  margin-bottom: 18rpx;
  color: inherit;
}

.item-name {
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.3;
  color: inherit;
}

.item-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
  line-height: 1.4;
  height: auto;
  max-height: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-count {
  position: absolute;
  bottom: 32rpx;
  right: 36rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.item-arrow {
  position: absolute;
  top: 36rpx;
  right: 36rpx;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 推荐合集特定样式 - 单列大卡片 */
.preset-list {
  flex-direction: row; /* 横向排列 */
  overflow-x: scroll; /* 允许横向滚动 */
  white-space: nowrap; /* 不换行 */
  -webkit-overflow-scrolling: touch; /* 增强滑动体验 */
  padding: 0 40rpx; /* 内部左右边距，与header对齐 */
  gap: 32rpx; /* 间距 */
  flex-wrap: nowrap; /* 强制不换行 */
  margin-bottom: 50rpx;
}

.preset-item {
  width: 600rpx; /* 固定宽度，确保多个卡片可并排 */
  flex-shrink: 0; /* 防止卡片收缩 */
  padding: 36rpx; /* 统一内边距 */
  min-height: 320rpx;
  background: linear-gradient(135deg, #fce3e8 0%, #fcc2cc 100%); /* 更温馨的粉色系渐变 */
  color: #333; /* 适配浅色背景的字体颜色 */
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.1); /* 稍强的阴影 */
  border: none;
}

.preset-item .item-icon {
  font-size: 76rpx;
  margin-bottom: 20rpx;
  color: #e91e63; /* 推荐卡片图标颜色 */
}

.preset-item .item-name {
  font-size: 44rpx;
  margin-top: 12rpx;
  color: #2a2a2a;
}

.preset-item .item-desc {
  font-size: 28rpx;
  max-height: 100rpx;
  -webkit-line-clamp: 3;
  margin-bottom: 24rpx;
  color: #666;
}
.preset-item .item-count {
  color: #999;
}

.preset-item .item-arrow {
  color: #ccc;
}


/* 来源合集特定样式 - 双列小卡片 */
.source-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 0 40rpx;
  margin-bottom: 40rpx;
}

.source-item {
  width: 100%;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 24rpx 16rpx;
  min-height: 0;
  border-radius: 20rpx;
  background-color: #ffffff;
  color: #333;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: none;
}

.source-item .item-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  color: #555;
}

.source-item .item-name {
  font-size: 26rpx;
  font-weight: 500;
  margin: 0;
  color: #333;
  line-height: 1.4;
}

.source-item .item-count {
  position: static;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.source-item .item-arrow {
  display: none;
}


/* 查看所有卡片按钮 */
.all-cards-btn {
  background: linear-gradient(135deg, #fdfdfd 0%, #f0f0f0 100%);
  color: #666;
  text-align: center;
  padding: 32rpx 0;
  border-radius: 36rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 36rpx 40rpx 0;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.2s cubic-bezier(0.2, 0, 0, 1);
  border: 1rpx solid #eee;
}

.all-cards-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 9rpx rgba(0, 0, 0, 0.03);
}

/* 底部安全区 - 由 .page padding-bottom 处理 */