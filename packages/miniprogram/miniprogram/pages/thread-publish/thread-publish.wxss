.page {
  min-height: 100vh;
  background: #fafafa;
  color: #111;
}
.publish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
}
.header-cancel {
  font-size: 28rpx;
  color: #888;
  width: 80rpx;
}
.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
}
.header-submit {
  font-size: 28rpx;
  font-weight: 700;
  color: #ccc;
  width: 80rpx;
  text-align: right;
}
.header-submit-active {
  color: #2563eb;
}
.publish-body {
  padding: 32rpx 40rpx;
}
.content-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}
.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}
.author-avatar-placeholder {
  background: #e0e0e0;
}
.content-input {
  flex: 1;
  min-height: 200rpx;
  background: transparent;
  color: #111;
  font-size: 32rpx;
  line-height: 1.6;
}
.image-preview-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.image-preview-item {
  position: relative;
  height: 200rpx;
  aspect-ratio: 1;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.remove-img {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tag-selector {
  margin-bottom: 32rpx;
}
.selector-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}
.selector-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.selector-tag {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  border: 1rpx solid #eee;
  font-size: 26rpx;
  color: #555;
  font-weight: 500;
}
.selector-tag-active {
  background: #111;
  color: #fff;
  border-color: #111;
}
.add-image-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid #f0f0f0;
}
.add-image-icon {
  font-size: 40rpx;
}
.add-image-text {
  font-size: 28rpx;
  color: #888;
}
