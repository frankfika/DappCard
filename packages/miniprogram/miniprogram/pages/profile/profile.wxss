/* miniprogram/pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* Profile Header */
.profile-header {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
}

.avatar-placeholder {
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.user-bio {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  max-width: 500rpx;
}

/* Stats Row */
.stats-row {
  background: #ffffff;
  margin: -50rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 138, 128, 0.15);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #ff8a80;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #eeeeee;
}

/* Edit Button */
.edit-btn {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  padding: 24rpx 0;
  margin: 0 30rpx 30rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 138, 128, 0.3);
}

/* Menu Section */
.menu-section {
  background: #ffffff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  font-size: 32rpx;
  color: #4a3f3a;
}

.menu-arrow {
  font-size: 48rpx;
  color: #cccccc;
  font-weight: 300;
}

/* Login Prompt */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
  line-height: 1;
}

.prompt-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.login-btn {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255, 138, 128, 0.3);
}

.login-btn::after {
  border: none;
}

/* Agreement Checkbox */
.agreement-check {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 0 40rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #cccccc;
  border-radius: 6rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  border-color: #ff8a80;
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
  line-height: 1;
}

.agreement-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.agreement-link {
  color: #ff8a80;
}
