/* pages/activity-detail/activity-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #fef7f4;
  padding-bottom: 200rpx;
}

.section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 20rpx;
}

/* Activity Info */
.activity-info {
  padding: 40rpx 30rpx;
}

.activity-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #4a3f3a;
  margin-bottom: 30rpx;
  line-height: 1.4;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.location-link {
  color: #ff8a80;
  text-decoration: underline;
}

.description {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.description-text {
  font-size: 28rpx;
  color: #4a3f3a;
  line-height: 1.6;
}

/* Activity Images */
.activity-images {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  overflow-x: auto;
}

.activity-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* Location Map */
.location-map {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  margin-top: 30rpx;
}

/* Participants */
.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.participant-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.participant-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-bottom: 12rpx;
  border: 3rpx solid #ffe8e5;
}

.participant-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

/* Applicants */
.applicant-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.applicant-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fef7f4;
  border-radius: 12rpx;
}

.applicant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.applicant-name {
  flex: 1;
  font-size: 28rpx;
  color: #4a3f3a;
}

.approve-btn {
  padding: 12rpx 32rpx;
  background-color: #ff8a80;
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
}

/* Comments */
.comments-section {
  min-height: 400rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.comment-item {
  display: flex;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.comment-name {
  font-size: 26rpx;
  color: #4a3f3a;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.empty-comments {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.action-btn.disabled {
  background: #e0e0e0;
  color: #999;
}

/* Comment Bar */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #4a3f3a;
}

.send-btn {
  padding: 12rpx 32rpx;
  height: 72rpx;
  background-color: #e0e0e0;
  color: #999;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn.active {
  background-color: #ff8a80;
  color: #fff;
}

/* Loading State */
.loading-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fef7f4;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
