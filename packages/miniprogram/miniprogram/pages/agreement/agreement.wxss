/* 用户服务协议样式 */
.container {
  min-height: 100vh;
  background: #fef7f4;
}

.content {
  padding: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a3f3a;
  text-align: center;
  margin-bottom: 16rpx;
}

.update-time {
  font-size: 24rpx;
  color: #b5a9a3;
  text-align: center;
  margin-bottom: 48rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff8a80;
}

.section-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  padding: 0 8rpx;
}
