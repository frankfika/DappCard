<!-- 收藏页 - 硅谷极简风格 -->
<view class="page">
  <!-- 头部 -->
  <view class="header">
    <text class="header-count">{{favorites.length}}</text>
    <text class="header-label">{{t.favorites.count}}</text>
  </view>

  <!-- 收藏列表 -->
  <view class="list" wx:if="{{favorites.length > 0}}">
    <view
      class="card-item"
      wx:for="{{favorites}}"
      wx:key="id"
      bindtap="viewCard"
      data-index="{{index}}"
    >
      <view class="card-icon-wrap {{item.type}}">
        <text class="card-icon">{{item.typeIcon}}</text>
      </view>
      <view class="card-body">
        <text class="card-text">{{item.question}}</text>
        <view class="card-meta">
          <text class="card-mode">{{item.modeName}}</text>
          <text class="card-type">{{item.typeLabel}}</text>
        </view>
      </view>
      <view class="card-del" catchtap="removeFavorite" data-id="{{item.id}}">
        <text>×</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <view class="empty-icon">
      <view class="empty-heart"></view>
    </view>
    <text class="empty-title">{{t.favorites.empty}}</text>
    <text class="empty-desc">{{t.favorites.emptyDesc}}</text>
    <view class="empty-btn" bindtap="goPlay">{{t.favorites.goPlay}}</view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>

<!-- 详情弹窗 -->
<view class="modal {{showModal ? 'show' : ''}}" bindtap="closeModal">
  <view class="modal-box" catchtap="">
    <view class="modal-header {{currentCard.type}}" wx:if="{{currentCard}}">
      <text class="modal-icon">{{currentCard.typeIcon}}</text>
      <text class="modal-type">{{currentCard.typeLabel}}</text>
    </view>
    <view class="modal-body" wx:if="{{currentCard}}">
      <text class="modal-text">{{currentCard.question}}</text>
      <view class="modal-tips" wx:if="{{currentCard.tips}}">
        <text>{{currentCard.tips}}</text>
      </view>
      <text class="modal-mode">{{currentCard.modeName}}</text>
    </view>
    <view class="modal-close" bindtap="closeModal">{{t.favorites.close}}</view>
  </view>
</view>
