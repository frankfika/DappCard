/**
 * 设置页样式 - 温馨浪漫风格
 */

.page {
  min-height: 100vh;
  padding: 0 32rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #fef7f4 0%, #fff5f3 100%);
}

/* ==================== 统计卡片 ==================== */
.stats-card {
  position: relative;
  margin: 32rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #ff8a80 0%, #f48fb1 50%, #ce93d8 100%);
  box-shadow: 0 8rpx 32rpx rgba(255, 138, 128, 0.35);
}

.stats-bg {
  display: none;
}

.stats-content {
  position: relative;
  padding: 32rpx;
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.25);
}

.overall-progress {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.overall-progress .progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.overall-progress .progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.overall-progress .progress-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  display: block;
}

/* ==================== 分区 ==================== */
.section {
  margin-bottom: 28rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  color: #b5a9a3;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  letter-spacing: 1rpx;
}

/* ==================== 菜单卡片 ==================== */
.menu-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(255, 138, 128, 0.1);
  border: 1rpx solid rgba(255, 138, 128, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 138, 128, 0.06);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fff8f7;
}

/* 图标容器 */
.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrap.green { background: linear-gradient(135deg, rgba(165, 214, 167, 0.2) 0%, rgba(129, 199, 132, 0.15) 100%); }
.menu-icon-wrap.pink { background: linear-gradient(135deg, rgba(255, 138, 128, 0.15) 0%, rgba(244, 143, 177, 0.1) 100%); }
.menu-icon-wrap.orange { background: linear-gradient(135deg, rgba(255, 171, 145, 0.15) 0%, rgba(255, 204, 188, 0.1) 100%); }
.menu-icon-wrap.purple { background: linear-gradient(135deg, rgba(206, 147, 216, 0.15) 0%, rgba(244, 143, 177, 0.1) 100%); }

.menu-icon {
  font-size: 28rpx;
}

/* 菜单内容 */
.menu-body {
  flex: 1;
}

.menu-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #4a3f3a;
  margin-bottom: 6rpx;
}

.menu-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 6rpx;
  background: #fce4df;
  border-radius: 3rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff8a80 0%, #f48fb1 100%);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #8b7e78;
  min-width: 60rpx;
}

.menu-action {
  font-size: 22rpx;
  color: #ff8a80;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fce4ec 100%);
  border-radius: 16rpx;
  margin-left: 16rpx;
}

/* 简单菜单项 */
.menu-item.simple {
  padding: 28rpx 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #4a3f3a;
}

.menu-value {
  font-size: 24rpx;
  color: #8b7e78;
}

.menu-arrow {
  font-size: 28rpx;
  color: #f8bbd9;
  margin-left: 8rpx;
}

.menu-item.danger .menu-text {
  color: #ff8a80;
}

/* 分享按钮样式重置 */
.share-btn {
  background: transparent;
  line-height: normal;
  margin: 0;
  padding: 28rpx 24rpx;
}

.share-btn::after {
  border: none;
}

/* ==================== 底部 ==================== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.footer-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3f3a;
  margin-bottom: 8rpx;
}

.footer-sub {
  font-size: 22rpx;
  color: #8b7e78;
  margin-bottom: 24rpx;
}

.footer-note {
  font-size: 20rpx;
  color: #f8bbd9;
}

/* ==================== 底部占位 ==================== */
.bottom-space {
  height: 40rpx;
}
