  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#fef7f4",
    "navigationBarTitleText": "心动卡片",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#fef7f4"
  },
  "tabBar": {
    "color": "#b5a9a3",
