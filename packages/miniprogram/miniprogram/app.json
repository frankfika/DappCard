        "selectedIconPath": "images/tab_home_active.png"
      },
      {
        "pagePath": "pages/discover/discover",
        "text": "发现",
        "iconPath": "images/tab_heart.png",
        "selectedIconPath": "images/tab_heart_active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "images/tab_settings.png",
        "selectedIconPath": "images/tab_settings_active.png"
      }
    ]
  },
  "usingComponents": {
    "user-avatar": "/components/user-avatar/user-avatar",
    "tag-selector": "/components/tag-selector/tag-selector",
    "profile-card": "/components/profile-card/profile-card",
    "activity-card": "/components/activity-card/activity-card",
    "empty-state": "/components/empty-state/empty-state"
  },
  "requiredPrivateInfos": [
    "getLocation",
    "chooseLocation"
  ],
  "permission": {
    "scope.userLocation": {
      "desc": "用于发现附近的搭子活动"
    }
  },
  "__usePrivacyCheck__": true,
  "style": "v2",
  "sitemapLocation": "sitemap.json"
