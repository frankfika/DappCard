.tag-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 48rpx;
  border: 2px solid #f0e8e4;
  background: #fff;
  color: var(--color-text);
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.tag-item:active {
  transform: scale(0.96);
}

.tag-selected {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, #fff0ef 0%, #ffe8e8 100%);
  color: var(--color-primary);
  font-weight: 500;
}

.tag-icon {
  font-size: 32rpx;
  line-height: 1;
}

.tag-name {
  line-height: 1;
}
