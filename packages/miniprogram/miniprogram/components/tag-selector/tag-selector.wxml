<view class="tag-selector">
  <view
    wx:for="{{tags}}"
    wx:key="id"
    class="tag-item {{selectedIds.indexOf(item.id) > -1 ? 'tag-selected' : ''}}"
    style="{{item.color ? 'border-color: ' + item.color : ''}}"
    data-id="{{item.id}}"
    bindtap="onTagTap"
  >
    <text wx:if="{{item.icon}}" class="tag-icon">{{item.icon}}</text>
    <text class="tag-name">{{item.name}}</text>
  </view>
</view>
