.activity-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 138, 128, 0.1);
  transition: all 0.2s ease;
}

.activity-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 138, 128, 0.15);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffeded 100%);
  border-bottom: 1px solid #ffe5e5;
}

.category-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.category-icon {
  font-size: 32rpx;
  line-height: 1;
}

.category-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.subcategory {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 4rpx 12rpx;
  background: rgba(255, 138, 128, 0.1);
  border-radius: 12rpx;
}

.card-body {
  padding: 32rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.4;
  display: block;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.activity-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-icon {
  font-size: 28rpx;
  line-height: 1;
}

.detail-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.3;
}

.card-footer {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.participant-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.participant-avatars {
  display: flex;
  align-items: center;
}

.participant-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.participant-bar {
  height: 8rpx;
  background: #f0e8e4;
  border-radius: 8rpx;
  overflow: hidden;
}

.participant-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-accent) 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}
