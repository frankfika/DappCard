<view class="activity-card" bindtap="onCardTap">
  <view class="card-header">
    <view class="category-badge">
      <text class="category-icon">{{getCategoryIcon(activity.category)}}</text>
      <text class="category-text">{{activity.category}}</text>
    </view>
    <view wx:if="{{activity.subcategory}}" class="subcategory">
      {{activity.subcategory}}
    </view>
  </view>

  <view class="card-body">
    <text class="activity-title">{{activity.title}}</text>

    <view class="activity-details">
      <view class="detail-item">
        <text class="detail-icon">🕐</text>
        <text class="detail-text">{{formatDateTime(activity.datetime)}}</text>
      </view>

      <view wx:if="{{activity.location}}" class="detail-item">
        <text class="detail-icon">📍</text>
        <text class="detail-text">{{activity.location}}</text>
      </view>
    </view>

    <view class="card-footer">
      <view class="participant-info">
        <view class="participant-avatars">
          <user-avatar
            wx:if="{{activity.creator && activity.creator.avatar}}"
            src="{{activity.creator.avatar}}"
            size="small"
          />
        </view>
        <text class="participant-count">
          {{activity.currentParticipants || 0}}/{{activity.maxParticipants || 0}}人
        </text>
      </view>

      <view class="participant-bar">
        <view
          class="participant-fill"
          style="width: {{getParticipantRatio()}}%"
        ></view>
      </view>
    </view>
  </view>
</view>
