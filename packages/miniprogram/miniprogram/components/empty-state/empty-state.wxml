<view class="empty-state">
  <text class="empty-icon">{{icon}}</text>
  <text class="empty-title">{{title}}</text>
  <text wx:if="{{description}}" class="empty-description">{{description}}</text>
  <button
    wx:if="{{showBtn}}"
    class="empty-action"
    bindtap="onActionTap"
  >
    {{btnText}}
  </button>
</view>
