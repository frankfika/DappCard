.user-avatar {
  position: relative;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid var(--color-primary);
  background: linear-gradient(135deg, #ffe5e5 0%, #fff5f5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-width: 1px;
}

.avatar-medium {
  width: 100rpx;
  height: 100rpx;
}

.avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-width: 3px;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 40rpx;
  opacity: 0.5;
}

.avatar-small .avatar-icon {
  font-size: 24rpx;
}

.avatar-large .avatar-icon {
  font-size: 64rpx;
}
